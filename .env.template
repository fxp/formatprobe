# LLM API 诊断工具 — API Key 配置
# 复制本文件为 .env，填入你的 Key，然后运行 run_providers.py
#
# 用法:
#   cp .env.template .env
#   vim .env
#   python3 run_providers.py

# ── 智谱 GLM ──────────────────────────────────────────────────────────────────
# 控制台: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=

# ── Moonshot KIMI ─────────────────────────────────────────────────────────────
# 控制台: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# ── Minimax ───────────────────────────────────────────────────────────────────
# 控制台: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=
# 旧版接口需要 GroupId（新版 OpenAI 兼容接口不需要，留空即可）
MINIMAX_GROUP_ID=

# ── 通义千问 Qwen / DashScope ─────────────────────────────────────────────────
# 控制台: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# 控制台: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# 控制台: https://openrouter.ai/keys
OPENROUTER_API_KEY=
